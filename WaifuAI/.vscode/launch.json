{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch (Avalonia)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net8.0/WaifuAI.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true,
            "env": {
                "AVALONIA_RENDERER": "Skia"
            }
        },
        {
            "name": ".NET Run (No Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net8.0/WaifuAI.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "noDebug": true,
            "env": {
                "AVALONIA_RENDERER": "Skia"
            }
        }
    ]
}