<Application 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="WaifuAI.App"
    xmlns:local="using:WaifuAI"
    RequestedThemeVariant="Default">
    <Application.Resources>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent"/>
        <SolidColorBrush x:Key="ListBoxBorderThemeBrush" Color="{DynamicResource SystemBaseLowColor}"/>
        <FontFamily x:Key="CascadiaCode">avares://WaifuAI/Assets/Fonts/#Cascadia Code</FontFamily>
        <FontFamily x:Key="JetBrainsMono">avares://WaifuAI/Assets/Fonts/#JetBrains Mono</FontFamily>
        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{DynamicResource SystemChromeHighColor}"/>
    </Application.Resources>
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources 
                    x:Key="Light" 
                    RegionColor="#eef1f5"
                    ChromeLow="#eef1f5"
                    ChromeMedium="#e5e8ee"
                    ChromeHigh="#dbdfe7"
                    BaseHigh="#4d5069"
                    BaseMediumHigh="#696c82"
                    BaseMedium="#84889a"
                    BaseMediumLow="#a0a4b3"
                    BaseLow="#bbbfcb"/>
                <ColorPaletteResources 
                    x:Key="Dark" 
                    RegionColor="#232332"
                    ChromeLow="#232332"
                    ChromeMedium="#1e1e2a"
                    ChromeHigh="#181821"
                    BaseHigh="#c5cff5"
                    BaseMediumHigh="#a1a9ca"
                    BaseMedium="#7d829e"
                    BaseMediumLow="#595c72"
                    BaseLow="#343546"/>
            </FluentTheme.Palettes>
        </FluentTheme>
        <StyleInclude Source="/Views/SettingsCard.axaml" />
    </Application.Styles>
</Application>