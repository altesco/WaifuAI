<Window
    x:Class="WaifuAI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:WaifuAI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WaifuAI.Models"
    xmlns:views="using:WaifuAI.Views"
    xmlns:vm="using:WaifuAI.ViewModels"
    xmlns:wv="clr-namespace:WebViewControl;assembly=WebViewControl.Avalonia"
    Title="WaifuAI"
    d:DesignHeight="720"
    d:DesignWidth="1024"
    x:DataType="vm:MainVM"
    Closed="Window_Closed"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="40"
    ExtendClientAreaToDecorationsHint="True"
    FontFamily="{Binding SelectedFontFamily, Source={x:Static vm:SettingsVM.Instance}}"
    Icon="/Assets/avalonia-logo.ico"
    Loaded="Window_OnLoaded"
    mc:Ignorable="d">
    <Window.Resources>
        <conv:MathConverter x:Key="MathConverter" />
        <conv:StringValueConverter x:Key="StringValueConverter" />
    </Window.Resources>
    <Grid
        x:Name="RootPanel"
        Margin="{Binding $parent[Window].OffScreenMargin}"
        Focusable="True"
        PointerPressed="OnBackgroundPointerPressed">
        <Grid.Styles>
            <Style Selector="TextBlock:disabled">
                <Setter Property="Foreground" Value="{DynamicResource SystemBaseMediumLowColor}" />
            </Style>
            <Style Selector="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseLowColor}" />
            </Style>
            <Style Selector="ListBox">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseLowColor}" />
            </Style>
            <Style Selector="Button.icon-button">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Cursor" Value="Hand" />
                <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                </Style>
            </Style>
            <Style Selector="Button.word-button">
                <Setter Property="Width" Value="NaN" />
                <Setter Property="Height" Value="32" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseLowColor}" />
                <Setter Property="Background" Value="{DynamicResource SystemChromeHighColor}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Padding" Value="12,0" />
                <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseMediumLowColor}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
                <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseMediumLowColor}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
            </Style>
            <Style Selector="ToggleButton">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Cursor" Value="Hand" />
                <Style Selector="^:checked:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="^:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
                <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundPointerOver}" />
                </Style>
                <Style Selector="^:checked  /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentButtonBackground}" />
                </Style>
            </Style>
            <Style Selector="ContextMenu">
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Background" Value="{DynamicResource SystemChromeMediumColor}" />
                <Setter Property="Padding" Value="6,1,6,1" />
                <Setter Property="Cursor" Value="Arrow" />
            </Style>
            <Style Selector="MenuItem">
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot, MenuItem:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
            </Style>
            <Style Selector="LucideIcon:disabled">
                <Setter Property="Opacity" Value="0.5" />
            </Style>
            <Style Selector="TextBox">
                <Setter Property="Background" Value="{DynamicResource SystemChromeHighColor}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SystemBaseMediumLowColor}" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="FontFamily" Value="{Binding SelectedMonoFontFamily, Source={x:Static vm:SettingsVM.Instance}}" />
                <Setter Property="Height" Value="30" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="10,0,10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem
                                Command="{Binding $parent[TextBox].Copy}"
                                Header="Копировать"
                                IsEnabled="{Binding $parent[TextBox].CanCopy}">
                                <MenuItem.Icon>
                                    <LucideIcon Kind="Copy" Size="20" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem
                                Command="{Binding ManualCut}"
                                CommandParameter="{Binding $parent[TextBox]}"
                                Header="Вырезать"
                                IsEnabled="{Binding $parent[TextBox].CanCut}">
                                <MenuItem.Icon>
                                    <LucideIcon Kind="Scissors" Size="20" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem
                                Command="{Binding $parent[TextBox].Paste}"
                                Header="Вставить"
                                IsEnabled="{Binding $parent[TextBox].CanPaste}">
                                <MenuItem.Icon>
                                    <LucideIcon Kind="ClipboardPaste" Size="20" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Command="{Binding $parent[TextBox].SelectAll}" Header="Выделить все">
                                <MenuItem.Icon>
                                    <LucideIcon Kind="SquareDashed" Size="20" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
                <Style Selector="^:disabled">
                    <Setter Property="Foreground" Value="{DynamicResource SystemBaseMediumLowColor}" />
                </Style>
            </Style>
            <Style Selector="Slider /template/ Thumb">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border
                            Width="20"
                            Height="20"
                            Background="{Binding $parent[Window].Background}"
                            BorderThickness="1"
                            CornerRadius="10" />
                    </ControlTemplate>
                </Setter>
            </Style>
            <Style Selector="ComboBox">
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Height" Value="30" />
                <Style Selector="^:dropdownopen /template/ Border#Background">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Style>
            </Style>
            <Style Selector="DataValidationErrors">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <ContentPresenter
                                Name="PART_ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                CornerRadius="{TemplateBinding CornerRadius}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style Selector="Arc.loading">
                <Style.Animations>
                    <Animation IterationCount="Infinite" Duration="0:0:1">
                        <KeyFrame Cue="0%">
                            <Setter Property="RotateTransform.Angle" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="RotateTransform.Angle" Value="360" />
                        </KeyFrame>
                    </Animation>
                    <Animation
                        Easing="SineEaseInOut"
                        IterationCount="Infinite"
                        Duration="0:0:2">
                        <KeyFrame Cue="0%">
                            <Setter Property="SweepAngle" Value="30" />
                            <Setter Property="StartAngle" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                            <Setter Property="SweepAngle" Value="270" />
                            <Setter Property="StartAngle" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="SweepAngle" Value="30" />
                            <Setter Property="StartAngle" Value="330" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="ToolTip">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="ShowDelay" Value="100" />
                <Setter Property="Transitions">
                    <Transitions>
                        <DoubleTransition
                            Easing="CircularEaseOut"
                            Property="Opacity"
                            Duration="0:0:0.2" />
                        <TransformOperationsTransition
                            Easing="BackEaseOut"
                            Property="RenderTransform"
                            Duration="0:0:0.25" />
                    </Transitions>
                </Setter>
            </Style>
            <Style Selector="ToolTip:open">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="RenderTransform" Value="scale(0.9)" />
            </Style>
            <Style Selector="ToolTip">
                <Setter Property="RenderTransform" Value="scale(0.8)" />
                <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            </Style>
        </Grid.Styles>
        <!--  Main  -->
        <Grid IsVisible="{Binding !IsInitializing}" RowDefinitions="40,*">
            <Classes.blurred>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="IsSettingsOpen" />
                    <Binding Path="IsPromptEditorOpen" />
                </MultiBinding>
            </Classes.blurred>
            <Grid.Styles>
                <Style Selector="Grid.blurred">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="10" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Styles>
            <Border
                Background="{DynamicResource SystemChromeHighColor}"
                BorderThickness="0,0,0,1"
                DoubleTapped="Border_DoubleTapped"
                PointerPressed="Border_PointerPressed">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40">
                            <LucideIcon
                                Kind="PawPrint"
                                Size="20"
                                StrokeWidth="2" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="DemiBold"
                            Text="WaifuAI" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="2"
                        Tag="{Binding IsWindows}">
                        <StackPanel.Styles>
                            <Style Selector="StackPanel[Tag=False]">
                                <Setter Property="Margin" Value="6,0,6,0" />
                            </Style>
                            <Style Selector="StackPanel[Tag=True]">
                                <Setter Property="Margin" Value="6,0,0,0" />
                            </Style>
                        </StackPanel.Styles>
                        <Button
                            Classes="icon-button"
                            ToolTip.HorizontalOffset="0"
                            ToolTip.Placement="Bottom"
                            ToolTip.Tip="Поиск"
                            ToolTip.VerticalOffset="4">
                            <LucideIcon Kind="Search" Size="20" />
                        </Button>
                        <Button
                            Classes="icon-button"
                            Command="{Binding SettingsCommand}"
                            ToolTip.HorizontalOffset="0"
                            ToolTip.Placement="BottomEdgeAlignedLeft"
                            ToolTip.Tip="Настройки"
                            ToolTip.VerticalOffset="4">
                            <LucideIcon Kind="Settings" Size="20" />
                        </Button>
                        <CaptionButtons
                            MaxHeight="100"
                            IsVisible="{Binding IsWindows}"
                            Tag="{Binding IsMaximized}">
                            <CaptionButtons.Styles>
                                <Style Selector="CaptionButtons[Tag=False] Button#PART_RestoreButton Path">
                                    <Setter Property="Data" Value="M2048 2048v-2048h-2048v2048h2048zM1843 1843h-1638v-1638h1638v1638z" />
                                </Style>
                                <Style Selector="CaptionButtons[Tag=True] Button#PART_RestoreButton Path">
                                    <Setter Property="Data" Value="M2048 410h-410v-410h-1638v1638h410v410h1638v-1638zM1434 1434h-1229v-1229h1229v1229zM1843 1843h-1229v-205h1024v-1024h205v1229z" />
                                </Style>
                                <Style Selector="Button">
                                    <Setter Property="Width" Value="44" />
                                    <Setter Property="Height" Value="39" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>
                                <Style Selector="Button#PART_MinimizeButton:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                                </Style>
                                <Style Selector="Button#PART_RestoreButton:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                                    <Setter Property="Opacity" Value="0.7" />
                                </Style>
                                <Style Selector="Button#PART_CloseButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.7" Color="Red" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Opacity" Value="0.7" />
                                </Style>
                                <Style Selector="Button#PART_CloseButton:pointerover Path">
                                    <Setter Property="Stroke" Value="White" />
                                    <Setter Property="Fill" Value="White" />
                                </Style>
                            </CaptionButtons.Styles>
                        </CaptionButtons>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid x:Name="MainGrid" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="400" MinWidth="400" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="350" MinWidth="256" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource SystemChromeMediumColor}" BorderThickness="0,0,1,0">
                    <StackPanel
                        Margin="5"
                        HorizontalAlignment="Center"
                        Spacing="4">
                        <ToggleButton
                            x:Name="ChatButton"
                            IsChecked="True"
                            IsCheckedChanged="LeftToggleButton_OnIsCheckedChanged"
                            ToolTip.HorizontalOffset="4"
                            ToolTip.Placement="Right"
                            ToolTip.Tip="Чат"
                            ToolTip.VerticalOffset="0">
                            <LucideIcon Kind="MessageSquareText" Size="20" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="MemoryButton"
                            IsCheckedChanged="LeftToggleButton_OnIsCheckedChanged"
                            ToolTip.HorizontalOffset="4"
                            ToolTip.Placement="Right"
                            ToolTip.Tip="База знаний"
                            ToolTip.VerticalOffset="0">
                            <LucideIcon Kind="BookText" Size="20" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="PersonalityButton"
                            IsCheckedChanged="LeftToggleButton_OnIsCheckedChanged"
                            ToolTip.HorizontalOffset="4"
                            ToolTip.Placement="Right"
                            ToolTip.Tip="Личность"
                            ToolTip.VerticalOffset="0">
                            <LucideIcon Kind="Brain" Size="20" />
                        </ToggleButton>
                    </StackPanel>
                </Border>
                <!--  LeftPanel  -->
                <Border
                    Grid.Column="1"
                    Background="{DynamicResource SystemChromeMediumColor}"
                    BorderThickness="0,0,1,0">
                    <Panel>
                        <!--  Chat  -->
                        <views:SidePanel Header="Чат" IsVisible="{Binding #ChatButton.IsChecked}">
                            <Grid RowDefinitions="*,Auto">
                                <ListBox
                                    x:Name="MessageList"
                                    Padding="6"
                                    Background="{DynamicResource SystemChromeMediumColor}"
                                    ItemsSource="{Binding Chat}"
                                    SelectedItem="{Binding SelectedMessage, Mode=TwoWay}">
                                    <ListBox.Styles>
                                        <Style Selector="ListBox /template/ ItemsPresenter">
                                            <Setter Property="MaxWidth" Value="720" />
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemContainerTheme>
                                        <ControlTheme TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="6" />
                                            <Setter Property="Background" Value="Transparent" />
                                        </ControlTheme>
                                    </ListBox.ItemContainerTheme>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border
                                                    MinHeight="32"
                                                    MaxWidth="360"
                                                    Padding="12,6,12,6"
                                                    Background="{DynamicResource SystemListLowColor}"
                                                    Tag="{Binding MessageModel.Role}">
                                                    <Border.Styles>
                                                        <Style Selector="Border">
                                                            <Setter Property="Grid.Column" Value="2" />
                                                            <Setter Property="CornerRadius" Value="16,16,4,16" />
                                                            <Setter Property="ContextMenu">
                                                                <Setter.Value>
                                                                    <ContextMenu>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            Command="{Binding CopyMessageTextCommand}"
                                                                            CommandParameter="{Binding #PART_SelectableTextBlock}"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Header="Копировать текст">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Copy" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            Command="{Binding MakeReplyCommand}"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Header="Ответить на сообщение">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="MessageSquareReply" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem Header="Удалить">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Trash2" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                    </ContextMenu>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                        <Style Selector="Border[Tag=assistant]">
                                                            <Setter Property="Grid.Column" Value="0" />
                                                            <Setter Property="CornerRadius" Value="16,16,16,4" />
                                                            <Setter Property="ContextMenu">
                                                                <Setter.Value>
                                                                    <ContextMenu>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            Command="{Binding CopyMessageTextCommand}"
                                                                            CommandParameter="{Binding #PART_SelectableTextBlock}"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Header="Копировать текст">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Copy" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            Command="{Binding MakeReplyCommand}"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Header="Ответить на сообщение">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="MessageSquareReply" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                        <MenuItem Header="Удалить">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Trash2" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                    </ContextMenu>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                        <Style Selector="Border[Tag=temp]">
                                                            <Setter Property="Grid.Column" Value="0" />
                                                            <Setter Property="CornerRadius" Value="16,16,16,4" />
                                                            <Setter Property="Width" Value="64" />
                                                            <Setter Property="ContextMenu" Value="{x:Null}" />
                                                        </Style>
                                                    </Border.Styles>
                                                    <Grid>
                                                        <StackPanel Spacing="2">
                                                            <Button
                                                                Width="Nan"
                                                                Height="Nan"
                                                                Padding="0"
                                                                BorderThickness="0"
                                                                CornerRadius="6,12,6,6"
                                                                IsVisible="{Binding ReplyMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                <Grid ColumnDefinitions="4,*">
                                                                    <Border
                                                                        Grid.Column="0"
                                                                        Width="4"
                                                                        Background="{DynamicResource SystemAccentColor}"
                                                                        CornerRadius="6,0,0,6" />
                                                                    <StackPanel
                                                                        Grid.Column="1"
                                                                        Margin="4"
                                                                        Spacing="2">
                                                                        <TextBlock
                                                                            HorizontalAlignment="Left"
                                                                            FontWeight="Bold"
                                                                            Tag="{Binding ReplyMessage.MessageModel.Role}"
                                                                            TextTrimming="CharacterEllipsis">
                                                                            <TextBlock.Styles>
                                                                                <Style Selector="TextBlock[Tag=assistant]">
                                                                                    <Setter Property="Text" Value="Вайфу" />
                                                                                </Style>
                                                                                <Style Selector="TextBlock[Tag=user]">
                                                                                    <Setter Property="Text" Value="Пользователь" />
                                                                                </Style>
                                                                            </TextBlock.Styles>
                                                                        </TextBlock>
                                                                        <TextBlock
                                                                            HorizontalAlignment="Left"
                                                                            Text="{Binding ReplyMessage.Quote}"
                                                                            TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Button>
                                                            <SelectableTextBlock
                                                                x:Name="PART_SelectableTextBlock"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Initialized="PART_SelectableTextBlock_Initialized"
                                                                SelectionEnd="{Binding SelectionEnd, Mode=TwoWay}"
                                                                SelectionStart="{Binding SelectionStart, Mode=TwoWay}"
                                                                Text="{Binding MessageModel.Content}"
                                                                TextWrapping="Wrap">
                                                                <SelectableTextBlock.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Tag="{Binding #PART_SelectableTextBlock.CanCopy}">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Copy" Size="20" />
                                                                            </MenuItem.Icon>
                                                                            <MenuItem.Styles>
                                                                                <Style Selector="MenuItem[Tag=True]">
                                                                                    <Setter Property="Header" Value="Копировать выделенное" />
                                                                                    <Setter Property="Command" Value="{Binding #PART_SelectableTextBlock.Copy}" />
                                                                                </Style>
                                                                                <Style Selector="MenuItem[Tag=False]">
                                                                                    <Setter Property="Header" Value="Копировать текст" />
                                                                                    <Setter Property="Command" Value="{Binding CopyMessageTextCommand}" />
                                                                                    <Setter Property="CommandParameter" Value="{Binding #PART_SelectableTextBlock}" />
                                                                                </Style>
                                                                            </MenuItem.Styles>
                                                                        </MenuItem>
                                                                        <MenuItem
                                                                            x:DataType="vm:MainVM"
                                                                            DataContext="{Binding $parent[ListBox].DataContext}"
                                                                            Tag="{Binding #PART_SelectableTextBlock.CanCopy}">
                                                                            <MenuItem.Styles>
                                                                                <Style Selector="MenuItem[Tag=True]">
                                                                                    <Setter Property="Header" Value="Ответить на цитату" />
                                                                                    <Setter Property="Icon">
                                                                                        <Setter.Value>
                                                                                            <Template>
                                                                                                <LucideIcon Kind="MessageSquareQuote" Size="20" />
                                                                                            </Template>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Setter Property="Command" Value="{Binding MakeQuoteCommand}" />
                                                                                    <Setter Property="CommandParameter" Value="{Binding #PART_SelectableTextBlock.SelectedText}" />
                                                                                </Style>
                                                                                <Style Selector="MenuItem[Tag=False]">
                                                                                    <Setter Property="Header" Value="Ответить на сообщение" />
                                                                                    <Setter Property="Icon">
                                                                                        <Setter.Value>
                                                                                            <Template>
                                                                                                <LucideIcon Kind="MessageSquareReply" Size="20" />
                                                                                            </Template>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Setter Property="Command" Value="{Binding MakeReplyCommand}" />
                                                                                </Style>
                                                                            </MenuItem.Styles>
                                                                        </MenuItem>
                                                                        <MenuItem Header="Удалить">
                                                                            <MenuItem.Icon>
                                                                                <LucideIcon Kind="Trash2" Size="20" />
                                                                            </MenuItem.Icon>
                                                                        </MenuItem>
                                                                    </ContextMenu>
                                                                </SelectableTextBlock.ContextMenu>
                                                            </SelectableTextBlock>
                                                            <TextBlock
                                                                HorizontalAlignment="Right"
                                                                FontSize="12"
                                                                IsVisible="{Binding MessageModel.Role, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter=temp}"
                                                                Opacity="0.5"
                                                                Text="{Binding Time}" />
                                                        </StackPanel>
                                                        <!--  Loading animation  -->
                                                        <StackPanel
                                                            Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            IsVisible="{Binding MessageModel.Role, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=temp}"
                                                            Orientation="Horizontal"
                                                            Spacing="5">
                                                            <StackPanel.Styles>
                                                                <Style Selector="Ellipse.dot">
                                                                    <Setter Property="Width" Value="8" />
                                                                    <Setter Property="Height" Value="8" />
                                                                    <Setter Property="Fill" Value="{DynamicResource SystemBaseHighColor}" />
                                                                    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
                                                                </Style>
                                                                <Style Selector="Ellipse.dot1">
                                                                    <Style.Animations>
                                                                        <Animation
                                                                            Delay="0:0:0.0"
                                                                            IterationCount="Infinite"
                                                                            Duration="0:0:1.2">
                                                                            <KeyFrame Cue="0%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="50%">
                                                                                <Setter Property="Opacity" Value="1" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="1.2" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="1.2" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="100%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                        </Animation>
                                                                    </Style.Animations>
                                                                </Style>
                                                                <Style Selector="Ellipse.dot2">
                                                                    <Style.Animations>
                                                                        <Animation
                                                                            Delay="0:0:0.4"
                                                                            IterationCount="Infinite"
                                                                            Duration="0:0:1.2">
                                                                            <KeyFrame Cue="0%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="50%">
                                                                                <Setter Property="Opacity" Value="1" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="1.2" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="1.2" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="100%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                        </Animation>
                                                                    </Style.Animations>
                                                                </Style>
                                                                <Style Selector="Ellipse.dot3">
                                                                    <Style.Animations>
                                                                        <Animation
                                                                            Delay="0:0:0.8"
                                                                            IterationCount="Infinite"
                                                                            Duration="0:0:1.2">
                                                                            <KeyFrame Cue="0%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="50%">
                                                                                <Setter Property="Opacity" Value="1" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="1.2" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="1.2" />
                                                                            </KeyFrame>
                                                                            <KeyFrame Cue="100%">
                                                                                <Setter Property="Opacity" Value="0.2" />
                                                                                <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                                                <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                                            </KeyFrame>
                                                                        </Animation>
                                                                    </Style.Animations>
                                                                </Style>
                                                            </StackPanel.Styles>
                                                            <Ellipse Classes="dot dot1" />
                                                            <Ellipse Classes="dot dot2" />
                                                            <Ellipse Classes="dot dot3" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <LucideIcon
                                                    Grid.Column="1"
                                                    Margin="6"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    IsVisible="{Binding IsFailed}"
                                                    Kind="CircleAlert"
                                                    Size="20" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <!--  Error Popup  -->
                                <Border
                                    MinHeight="60"
                                    MaxWidth="720"
                                    Margin="10"
                                    VerticalAlignment="Bottom"
                                    Background="#FF979C"
                                    BorderBrush="#842426"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <SelectableTextBlock
                                            x:Name="ErrorTextBlock"
                                            Margin="10,6,10,6"
                                            Foreground="#842426"
                                            Text="{Binding Error}"
                                            TextWrapping="Wrap">
                                            <SelectableTextBlock.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Command="{Binding #ErrorTextBlock.Copy}" Header="Копировать">
                                                        <MenuItem.Icon>
                                                            <LucideIcon Kind="Copy" Size="20" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </SelectableTextBlock.ContextMenu>
                                        </SelectableTextBlock>
                                        <Button
                                            Grid.Column="1"
                                            Width="24"
                                            Height="24"
                                            Margin="4"
                                            VerticalAlignment="Top"
                                            Classes="icon-button"
                                            Command="{Binding CloseErrorMessageCommand}"
                                            Foreground="#842426">
                                            <LucideIcon Kind="X" Size="18" />
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            Width="24"
                                            Height="24"
                                            Margin="4"
                                            VerticalAlignment="Bottom"
                                            Classes="icon-button"
                                            Click="CopyErrorButton_Click"
                                            Command="{Binding CopyMessageTextCommand}"
                                            CommandParameter="{Binding #ErrorTextBlock}"
                                            Foreground="#842426">
                                            <LucideIcon Kind="Copy" Size="14" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <!--  Text Input  -->
                                <Border
                                    Grid.Row="1"
                                    MaxWidth="720"
                                    Background="{DynamicResource SystemChromeHighColor}"
                                    Tag="{Binding $self.Bounds.Width}">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Setter Property="BorderThickness" Value="0,1,0,0" />
                                        </Style>
                                        <Style Selector="Border[Tag=720]">
                                            <Setter Property="Margin" Value="0,0,0,6" />
                                            <Setter Property="CornerRadius" Value="7" />
                                            <Setter Property="BorderThickness" Value="1,1,1,1" />
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Grid
                                            Grid.ColumnSpan="2"
                                            ColumnDefinitions="Auto,*,Auto"
                                            RowDefinitions="*,*">
                                            <LucideIcon
                                                Grid.RowSpan="2"
                                                Margin="10,0,10,0"
                                                IsVisible="{Binding ReplyMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                Size="24"
                                                Tag="{Binding ReplyMessage.IsReplied}">
                                                <LucideIcon.Styles>
                                                    <Style Selector="LucideIcon[Tag=true]">
                                                        <Setter Property="Kind" Value="MessageSquareReply" />
                                                    </Style>
                                                    <Style Selector="LucideIcon[Tag=false]">
                                                        <Setter Property="Kind" Value="MessageSquareQuote" />
                                                    </Style>
                                                </LucideIcon.Styles>
                                            </LucideIcon>
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,4,0,0"
                                                FontWeight="Bold"
                                                IsVisible="{Binding ReplyMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                Tag="{Binding ReplyMessage.IsReplied}"
                                                TextTrimming="CharacterEllipsis">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock[Tag=true]">
                                                        <Setter Property="Text" Value="Ответ на сообщение" />
                                                    </Style>
                                                    <Style Selector="TextBlock[Tag=false]">
                                                        <Setter Property="Text" Value="Ответ на цитату" />
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                IsVisible="{Binding ReplyMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                Text="{Binding ReplyMessage.Quote}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Button
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Grid.Column="2"
                                                Width="30"
                                                Height="30"
                                                Margin="6,0,6,0"
                                                VerticalAlignment="Center"
                                                Classes="icon-button"
                                                Command="{Binding ReleaseReplyAndQuoteCommand}"
                                                IsVisible="{Binding ReplyMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <LucideIcon Kind="X" />
                                            </Button>
                                        </Grid>
                                        <TextBox
                                            x:Name="TextBox"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Height="NaN"
                                            MinHeight="40"
                                            MaxHeight="300"
                                            Padding="12,6,12,6"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            FontFamily="{Binding SelectedFontFamily, Source={x:Static vm:SettingsVM.Instance}}"
                                            ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                            Text="{Binding Question, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap"
                                            Watermark="Сообщение...">
                                            <TextBox.Resources>
                                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBackgroundFocused">Transparent</SolidColorBrush>
                                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver">Transparent</SolidColorBrush>
                                            </TextBox.Resources>
                                            <TextBox.Styles>
                                                <Style Selector="Border">
                                                    <Setter Property="BorderThickness" Value="0" />
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <StackPanel
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Orientation="Horizontal">
                                            <Button
                                                Margin="3"
                                                Classes="icon-button"
                                                Command="{Binding QueryCommand}"
                                                CommandParameter="{Binding #MyWebView}"
                                                IsDefault="True"
                                                IsEnabled="{Binding Question, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <LucideIcon Kind="SendHorizontal" Size="20" />
                                            </Button>
                                            <Button Margin="3" Classes="icon-button">
                                                <LucideIcon Kind="Mic" Size="20" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </views:SidePanel>
                        <!--  Knowledge Base  -->
                        <views:SidePanel Header="База знаний" IsVisible="{Binding #MemoryButton.IsChecked}">
                            <DataGrid
                                VerticalAlignment="Top"
                                AutoGenerateColumns="False"
                                Background="{DynamicResource SystemChromeHighColor}"
                                CanUserResizeColumns="True"
                                GridLinesVisibility="All"
                                IsReadOnly="True"
                                ItemsSource="{Binding KnowledgeBase}"
                                RowBackground="{DynamicResource SystemChromeMediumLowColor}"
                                RowHeight="NaN"
                                UseLayoutRounding="True">
                                <DataGrid.Styles>
                                    <Style Selector="DataGridRow:nth-child(even)">
                                        <Setter Property="Background" Value="{DynamicResource SystemChromeMediumColor}" />
                                    </Style>
                                    <Style Selector="DataGridRow:pointerover">
                                        <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
                                    </Style>
                                    <Style Selector="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource SystemBaseHighColor}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="FontSize" Value="14" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Setter Property="Padding" Value="10,0,2,0" />
                                    </Style>
                                    <Style Selector="DataGridColumnHeader TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGrid.Styles>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn
                                        Width="32"
                                        CanUserResize="False"
                                        SortMemberPath="IsFavorite">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ToggleButton
                                                    Margin="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding $parent[DataGrid].((vm:MainVM)DataContext).ToggleFavoriteFactCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsChecked="{Binding IsFavorite, Mode=TwoWay}">
                                                    <LucideIcon Kind="Star" Size="18" />
                                                    <ToggleButton.Styles>
                                                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="Transparent" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemBaseMediumColor}" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:unchecked:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemBaseMediumLowColor}" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
                                                        </Style>
                                                    </ToggleButton.Styles>
                                                </ToggleButton>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn
                                        Width="2*"
                                        Header="Факт"
                                        SortMemberPath="Key">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0"
                                                    Padding="10,6"
                                                    VerticalAlignment="Top"
                                                    FontSize="14"
                                                    LineHeight="20"
                                                    Text="{Binding Key}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="2*" Header="Отношение">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0"
                                                    Padding="10,6"
                                                    VerticalAlignment="Top"
                                                    FontSize="14"
                                                    LineHeight="20"
                                                    LineSpacing="0"
                                                    MaxLines="5"
                                                    Text="{Binding Value}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="WrapWithOverflow" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn
                                        Width="2*"
                                        Header="Категория"
                                        SortMemberPath="Category">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0"
                                                    Padding="10,6"
                                                    VerticalAlignment="Top"
                                                    FontSize="14"
                                                    LineHeight="20"
                                                    Text="{Binding Category}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </views:SidePanel>
                        <!--  Personality  -->
                        <views:SidePanel Header="Личность" IsVisible="{Binding #PersonalityButton.IsChecked}">
                            <ListBox
                                Padding="0"
                                x:DataType="vm:SettingsVM"
                                Background="Transparent"
                                DataContext="{x:Static vm:SettingsVM.Instance}"
                                ItemsSource="{Binding Archetypes}"
                                SelectedItem="{Binding SelectedArchetype, Mode=TwoWay}">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="CornerRadius" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="MaxWidth" Value="720" />
                                        <Setter Property="Tag" Value="{Binding $self.Bounds.Width}" />
                                        <Style Selector="^[Tag=720]">
                                            <Setter Property="CornerRadius" Value="5" />
                                        </Style>
                                        <Style Selector="^[Tag=720]:nth-child(1)">
                                            <Setter Property="Margin" Value="0,8,0,0" />
                                        </Style>
                                        <Style Selector="^[Tag=720]:nth-last-child(1)">
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                        </Style>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource SystemChromeHighColor}" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <Button
                                                    Width="{Binding $self.Bounds.Height}"
                                                    Height="NaN"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Stretch"
                                                    x:DataType="vm:MainVM"
                                                    Classes="icon-button"
                                                    Command="{Binding PromptEditorCommand}"
                                                    DataContext="{Binding $parent[views:SidePanel].DataContext}"
                                                    IsVisible="{Binding $parent[ListBoxItem].IsSelected}"
                                                    ToolTip.Placement="Bottom"
                                                    ToolTip.Tip="Изменить промпт"
                                                    ToolTip.VerticalOffset="4">
                                                    <LucideIcon Kind="Pencil" Size="14" />
                                                </Button>
                                                <Border
                                                    Padding="8,2,6,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                    <Border.Background>
                                                        <SolidColorBrush Opacity="0.2" Color="{Binding Color}" />
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Border.BorderBrush>
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="{Binding Name}">
                                                            <TextBlock.Foreground>
                                                                <SolidColorBrush Color="{Binding Color}" />
                                                            </TextBlock.Foreground>
                                                        </TextBlock>
                                                        <TextBlock
                                                            MinWidth="0"
                                                            FontFamily="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji"
                                                            Text="{Binding Emoji}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <TextBlock
                                                Margin="6,0"
                                                Tag="{Binding $parent[ListBoxItem].IsSelected}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock[Tag=False]">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemBaseMediumHighColor}" />
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </views:SidePanel>
                    </Panel>
                </Border>
                <GridSplitter
                    Grid.Column="1"
                    Width="4"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    DragCompleted="LeftThumb_OnDragCompleted">
                    <GridSplitter.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding ElementName="ChatButton" Path="IsChecked" />
                            <Binding ElementName="MemoryButton" Path="IsChecked" />
                            <Binding ElementName="PersonalityButton" Path="IsChecked" />
                        </MultiBinding>
                    </GridSplitter.IsVisible>
                </GridSplitter>
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsVisible="{Binding Source={x:Static vm:SettingsVM.Instance}, Path=IsModel3DLoading}"
                    Spacing="4">
                    <Arc
                        Width="36"
                        Height="36"
                        Classes="loading"
                        Opacity="0.4"
                        StartAngle="0"
                        Stroke="{Binding $parent[Window].Foreground}"
                        StrokeLineCap="Round"
                        StrokeThickness="2"
                        SweepAngle="270">
                        <Arc.Transitions>
                            <Transitions>
                                <DoubleTransition Property="RotateTransform.Angle" Duration="0:0:1" />
                            </Transitions>
                        </Arc.Transitions>
                        <Arc.RenderTransform>
                            <RotateTransform />
                        </Arc.RenderTransform>
                    </Arc>
                </StackPanel>
                <Image x:Name="WebViewSnapshot" Grid.Column="2">
                    <Image.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding Path="IsSettingsOpen" />
                            <Binding Path="IsPromptEditorOpen" />
                        </MultiBinding>    
                    </Image.IsVisible>    
                </Image>
                <wv:WebView
                    x:Name="MyWebView"
                    Grid.Column="2"
                    Address="{Binding WebAddress}"
                    DisableBuiltinContextMenus="True"
                    JavascriptContextCreated="MyWebView_JavascriptContextCreated">
                    <wv:WebView.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsModel3DLoading" Source="{x:Static vm:SettingsVM.Instance}" />
                            <Binding Path="!IsSettingsOpen" />
                            <Binding Path="!IsPromptEditorOpen" />
                        </MultiBinding>
                    </wv:WebView.IsVisible>
                </wv:WebView>
                <!--  RightPanel  -->
                <Border
                    Grid.Column="3"
                    x:DataType="vm:SettingsVM"
                    Background="{DynamicResource SystemChromeMediumColor}"
                    BorderThickness="1,0,0,0"
                    DataContext="{x:Static vm:SettingsVM.Instance}"
                    IsVisible="{Binding #ModelButton.IsChecked}">
                    <Border.Styles>
                        <Style Selector="TextBox">
                            <Setter Property="CornerRadius" Value="5" />
                            <Setter Property="FontFamily" Value="{Binding SelectedMonoFontFamily, Source={x:Static vm:SettingsVM.Instance}}" />
                        </Style>
                        <Style Selector="StackPanel[Tag=False]">
                            <Setter Property="IsEnabled" Value="False" />
                        </Style>
                    </Border.Styles>
                    <Grid RowDefinitions="Auto,*">
                        <Border Height="48" BorderThickness="0,0,0,1">
                            <TextBlock
                                Margin="16,0,16,0"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Источник модели"
                                TextTrimming="CharacterEllipsis" />
                        </Border>
                        <ScrollViewer Grid.Row="1">
                            <StackPanel Margin="16,8,16,16" Spacing="8">
                                <RadioButton
                                    x:Name="ServerButton"
                                    GroupName="ModelSource"
                                    IsChecked="{Binding IsServerQuery}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="DemiBold"
                                        Text="Сервер"
                                        TextTrimming="CharacterEllipsis" />
                                </RadioButton>

                                <StackPanel Spacing="4" Tag="{Binding #ServerButton.IsChecked}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <LucideIcon
                                            Kind="Hash"
                                            Size="16"
                                            StrokeWidth="2" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="DemiBold"
                                            Text="Порт"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBox Text="{Binding Port, Mode=TwoWay}" />
                                    <Grid Margin="0,8,0,0" ColumnDefinitions="Auto,*">
                                        <LucideIcon
                                            Kind="Network"
                                            Size="16"
                                            StrokeWidth="2" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="DemiBold"
                                            Text="IP-адрес"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBox Text="{Binding IpAddress, Mode=TwoWay}" />
                                </StackPanel>

                                <RadioButton
                                    x:Name="ProviderButton"
                                    GroupName="ModelSource"
                                    IsChecked="{Binding !IsServerQuery}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="DemiBold"
                                        Text="Облачный провайдер" />
                                </RadioButton>

                                <StackPanel Spacing="4" Tag="{Binding #ProviderButton.IsChecked}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <LucideIcon
                                            Kind="KeyRound"
                                            Size="16"
                                            StrokeWidth="2" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="DemiBold"
                                            Text="API Ключ"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBox Text="{Binding ApiKey, Mode=TwoWay}" />
                                    <Grid Margin="0,8,0,0" ColumnDefinitions="Auto,*">
                                        <LucideIcon
                                            Kind="Link"
                                            Size="16"
                                            StrokeWidth="2" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="DemiBold"
                                            Text="API URL"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBox Text="{Binding ApiUrl, Mode=TwoWay}" />
                                    <Grid Margin="0,8,0,0" ColumnDefinitions="Auto,*">
                                        <LucideIcon
                                            Kind="Bot"
                                            Size="16"
                                            StrokeWidth="2" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="DemiBold"
                                            Text="Модель"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBox Text="{Binding AiModel, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <GridSplitter
                    Grid.Column="3"
                    Width="4"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    DragCompleted="RightThumb_OnDragCompleted">
                    <GridSplitter.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding ElementName="ModelButton" Path="IsChecked" />
                            <Binding ElementName="ParametersButton" Path="IsChecked" />
                        </MultiBinding>
                    </GridSplitter.IsVisible>
                </GridSplitter>
                <Border
                    Grid.Column="4"
                    Background="{DynamicResource SystemChromeMediumColor}"
                    BorderThickness="1,0,0,0">
                    <StackPanel
                        Margin="5"
                        HorizontalAlignment="Center"
                        Spacing="4">
                        <ToggleButton
                            x:Name="ParametersButton"
                            IsCheckedChanged="RightToggleButton_OnIsCheckedChanged"
                            ToolTip.HorizontalOffset="4"
                            ToolTip.Placement="Left"
                            ToolTip.Tip="Параметры ИИ"
                            ToolTip.VerticalOffset="0">
                            <LucideIcon Kind="Settings2" Size="20" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="ModelButton"
                            IsChecked="True"
                            IsCheckedChanged="RightToggleButton_OnIsCheckedChanged"
                            ToolTip.HorizontalOffset="4"
                            ToolTip.Placement="Left"
                            ToolTip.Tip="Источник модели"
                            ToolTip.VerticalOffset="0">
                            <LucideIcon Kind="Server" Size="20" />
                        </ToggleButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!--  Popups  -->
        <Grid>
            <Grid.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="IsSettingsOpen" />
                    <Binding Path="IsPromptEditorOpen" />
                </MultiBinding>
            </Grid.IsVisible>
            <Grid.Background>
                <SolidColorBrush Opacity="0.15" Color="Black" />
            </Grid.Background>

            <!--  Settings  -->
            <Border
                MaxWidth="1400"
                MaxHeight="900"
                Margin="52"
                Background="{DynamicResource SystemChromeLowColor}"
                BorderThickness="1"
                CornerRadius="8"
                IsVisible="{Binding IsSettingsOpen}">
                <Border.Styles>
                    <Style Selector="Separator">
                        <Setter Property="Height" Value="1" />
                        <Setter Property="Background" Value="{DynamicResource SystemBaseLowColor}" />
                        <Setter Property="Margin" Value="0,18,0,18" />
                    </Style>
                </Border.Styles>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
                    <TextBlock
                        Margin="16,12"
                        FontSize="22"
                        FontWeight="DemiBold"
                        Text="Настройки" />
                    <ListBox
                        Grid.Column="0"
                        Grid.Row="1"
                        Padding="10,0,10,10"
                        Background="Transparent">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="CornerRadius" Value="4" />
                                <Setter Property="Padding" Value="8,4,24,4" />
                                <Setter Property="Margin" Value="1" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
                            </Style>
                        </ListBox.Styles>
                        <ListBoxItem x:Name="General">
                            <Grid ColumnDefinitions="Auto,*">
                                <LucideIcon
                                    Margin="0,0,8,0"
                                    Kind="Wrench"
                                    Size="18" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Общие"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </ListBoxItem>
                        <ListBoxItem x:Name="Sound" IsSelected="True">
                            <Grid ColumnDefinitions="Auto,*">
                                <LucideIcon
                                    Margin="0,0,8,0"
                                    Kind="Volume2"
                                    Size="18" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Звук"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ModelAppearence">
                            <Grid ColumnDefinitions="Auto,*">
                                <LucideIcon
                                    Margin="0,0,8,0"
                                    Kind="Shirt"
                                    Size="18" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Внешний вид"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </ListBoxItem>
                        <ListBoxItem>
                            <Grid ColumnDefinitions="Auto,*">
                                <LucideIcon
                                    Margin="0,0,8,0"
                                    Kind="Info"
                                    Size="18" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="О программе"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </ListBoxItem>
                    </ListBox>
                    <ScrollViewer
                        Grid.Row="0"
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        x:DataType="vm:SettingsVM"
                        DataContext="{x:Static vm:SettingsVM.Instance}"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{DynamicResource SystemBaseLowColor}">
                        <Grid>
                            <Grid.Resources>
                                <ControlTheme x:Key="SettingsGroup" TargetType="Border">
                                    <Setter Property="Margin" Value="12" />
                                    <Setter Property="CornerRadius" Value="12" />
                                    <Setter Property="Padding" Value="18" />
                                    <Setter Property="Background" Value="{DynamicResource SystemChromeMediumColor}" />
                                </ControlTheme>
                            </Grid.Resources>
                            <Grid.Styles>
                                <Style Selector="Slider">
                                    <Setter Property="Width" Value="120" />
                                    <Setter Property="TickFrequency" Value="0.1" />
                                    <Setter Property="IsSnapToTickEnabled" Value="True" />
                                </Style>
                            </Grid.Styles>
                            <StackPanel Margin="24,12" IsVisible="{Binding #General.IsSelected}">
                                <TextBlock
                                    Margin="24,6,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Text="Оформление" />
                                <Border Theme="{DynamicResource SettingsGroup}">
                                    <StackPanel>
                                        <views:SettingsCard
                                            Description="Основная тема приложения"
                                            Header="Тема"
                                            Icon="{LucideIconContent SunMoon,
                                                                     20}">
                                            <ComboBox SelectedIndex="{Binding SelectedTheme, Mode=TwoWay}">
                                                <ComboBoxItem Content="Светлая" />
                                                <ComboBoxItem Content="Темная" />
                                                <ComboBoxItem Content="Система" />
                                            </ComboBox>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Выбор акцентного цвета приложения"
                                            Header="Акцентный цвет"
                                            Icon="{LucideIconContent Pipette,
                                                                     20}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock VerticalAlignment="Center" Text="HEX:" />
                                                <TextBox
                                                    Width="90"
                                                    Padding="6,0,6,0"
                                                    VerticalContentAlignment="Center"
                                                    Text="{Binding SelectedColor, Mode=TwoWay}"
                                                    Watermark="#RRGGBB" />
                                                <Border
                                                    Width="24"
                                                    Height="24"
                                                    Background="{DynamicResource SystemAccentColor}"
                                                    BorderBrush="{DynamicResource SystemAccentColorDark1}"
                                                    BorderThickness="1"
                                                    CornerRadius="12" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Выбор шрифта интерфейса приложения"
                                            Header="Шрифт"
                                            Icon="{LucideIconContent Type,
                                                                     20}">
                                            <ComboBox ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont, Mode=TwoWay}">
                                                <Interaction.Behaviors>
                                                    <EventTriggerBehavior EventName="DropDownOpened">
                                                        <InvokeCommandAction Command="{Binding RefreshFontsCommand}" />
                                                    </EventTriggerBehavior>
                                                </Interaction.Behaviors>
                                            </ComboBox>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Выбор используемого в приложении моноширинного шрифта"
                                            Header="Моноширинный шрифт"
                                            Icon="{LucideIconContent SquareTerminal,
                                                                     20}">
                                            <ComboBox ItemsSource="{Binding MonospaceFonts}" SelectedItem="{Binding SelectedMonoFont, Mode=TwoWay}">
                                                <Interaction.Behaviors>
                                                    <EventTriggerBehavior EventName="DropDownOpened">
                                                        <InvokeCommandAction Command="{Binding RefreshMonoFontsCommand}" />
                                                    </EventTriggerBehavior>
                                                </Interaction.Behaviors>
                                            </ComboBox>
                                        </views:SettingsCard>
                                    </StackPanel>
                                </Border>
                                <TextBlock
                                    Margin="24,0,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Text="Язык" />
                                <Border Theme="{DynamicResource SettingsGroup}">
                                    <StackPanel>
                                        <views:SettingsCard
                                            Description="Язык интерфейса всего приложения"
                                            Header="Язык интерфейса"
                                            Icon="{LucideIconContent Globe,
                                                                     20}">
                                            <ComboBox ItemsSource="{Binding AppLanguages}" SelectedItem="{Binding SelectedAppLanguage}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource StringValueConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Язык, на котором будет происходить общение с моделью. От этого параметра зависит список доступных голосовых моделей"
                                            Header="Язык модели"
                                            Icon="{LucideIconContent Languages,
                                                                     20}">
                                            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}">
                                                <ComboBox.IsEnabled>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="!IsSpeakersLoading" />
                                                        <Binding Path="!IsDownloading" />
                                                    </MultiBinding>
                                                </ComboBox.IsEnabled>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource StringValueConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </views:SettingsCard>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Margin="24,12" IsVisible="{Binding #Sound.IsSelected}">
                                <TextBlock
                                    Margin="24,6,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Text="Провайдер" />
                                <Border Theme="{DynamicResource SettingsGroup}">
                                    <StackPanel>
                                        <views:SettingsCard
                                            Description="Выбор технологии синтеза речи"
                                            Header="Источник"
                                            Icon="{LucideIconContent Cpu,
                                                                     20}">
                                            <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}">
                                                <ComboBox.IsEnabled>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="!IsSpeakersLoading" />
                                                        <Binding Path="!IsDownloading" />
                                                    </MultiBinding>
                                                </ComboBox.IsEnabled>
                                            </ComboBox>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Технологическая база для генерации речи"
                                            Header="Модель синтеза"
                                            Icon="{LucideIconContent Bot,
                                                                     20}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <StackPanel
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding IsDownloading}"
                                                    Spacing="2">
                                                    <Grid>
                                                        <TextBlock
                                                            FontFamily="{Binding SelectedMonoFontFamily}"
                                                            FontSize="12"
                                                            Text="{Binding DownloadSpeed, StringFormat={}{0} MB/s}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{Binding SelectedMonoFontFamily}"
                                                            FontSize="12"
                                                            Text="{Binding DownloadProgress, StringFormat={}{0}%}" />
                                                    </Grid>
                                                    <ProgressBar MinWidth="160" Value="{Binding DownloadProgress}" />
                                                </StackPanel>
                                                <Button Classes="icon-button" Command="{Binding DownloadVoiceModelCommand}">
                                                    <Button.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsSelectedVoiceModelLoaded" />
                                                            <Binding Path="!IsDownloading" />
                                                        </MultiBinding>
                                                    </Button.IsVisible>
                                                    <LucideIcon Kind="Download" Size="20" />
                                                </Button>
                                                <Button
                                                    Classes="icon-button"
                                                    Command="{Binding CancelDownloadCommand}"
                                                    IsVisible="{Binding IsDownloading}">
                                                    <LucideIcon Kind="CircleX" Size="18" />
                                                </Button>
                                                <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedVoiceModel}">
                                                    <ComboBox.IsEnabled>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsSpeakersLoading" />
                                                            <Binding Path="!IsDownloading" />
                                                        </MultiBinding>
                                                    </ComboBox.IsEnabled>
                                                </ComboBox>
                                            </StackPanel>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Конкретный голос и тембр, доступный в рамках выбранной модели"
                                            Header="Голос"
                                            Icon="{LucideIconContent Speech,
                                                                     20}">
                                            <Grid>
                                                <ComboBox ItemsSource="{Binding Speakers}" SelectedItem="{Binding SelectedSpeaker}">
                                                    <ComboBox.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsSpeakersLoading" />
                                                            <Binding Path="IsSelectedVoiceModelLoaded" />
                                                        </MultiBinding>
                                                    </ComboBox.IsVisible>
                                                </ComboBox>
                                                <Arc
                                                    Width="24"
                                                    Height="24"
                                                    Classes="loading"
                                                    IsVisible="{Binding IsSpeakersLoading}"
                                                    Opacity="0.4"
                                                    StartAngle="0"
                                                    Stroke="{Binding $parent[Window].Foreground}"
                                                    StrokeLineCap="Round"
                                                    StrokeThickness="2"
                                                    SweepAngle="270">
                                                    <Arc.RenderTransform>
                                                        <RotateTransform />
                                                    </Arc.RenderTransform>
                                                </Arc>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontWeight="DemiBold"
                                                    Text="Загрузите модель">
                                                    <TextBlock.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsSpeakersLoading" />
                                                            <Binding Path="!IsSelectedVoiceModelLoaded" />
                                                        </MultiBinding>
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                            </Grid>
                                        </views:SettingsCard>
                                    </StackPanel>
                                </Border>
                                <TextBlock
                                    Margin="24,0,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Text="Голос" />
                                <Border Theme="{DynamicResource SettingsGroup}">
                                    <StackPanel>
                                        <views:SettingsCard
                                            Description="Общая громкость голоса"
                                            Header="Громкость"
                                            Tag="{Binding VolumeLevel}">
                                            <views:SettingsCard.Styles>
                                                <Style Selector="views|SettingsCard[Tag=0]">
                                                    <Setter Property="Icon">
                                                        <Setter.Value>
                                                            <Template>
                                                                <LucideIcon Kind="VolumeX" Size="20" />
                                                            </Template>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <Style Selector="views|SettingsCard[Tag=1]">
                                                    <Setter Property="Icon">
                                                        <Setter.Value>
                                                            <Template>
                                                                <LucideIcon Kind="Volume" Size="20" />
                                                            </Template>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <Style Selector="views|SettingsCard[Tag=2]">
                                                    <Setter Property="Icon">
                                                        <Setter.Value>
                                                            <Template>
                                                                <LucideIcon Kind="Volume1" Size="20" />
                                                            </Template>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <Style Selector="views|SettingsCard[Tag=3]">
                                                    <Setter Property="Icon">
                                                        <Setter.Value>
                                                            <Template>
                                                                <LucideIcon Kind="Volume2" Size="20" />
                                                            </Template>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </views:SettingsCard.Styles>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Slider
                                                    Maximum="2.0"
                                                    Minimum="0.0"
                                                    Value="{Binding Volume, Mode=TwoWay}" />
                                                <TextBox
                                                    Width="64"
                                                    HorizontalContentAlignment="Center"
                                                    Text="{Binding Volume, Mode=TwoWay, StringFormat='{}{0:0.0}'}" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Регулировка высоты тона: низкие значения делают голос более грубым и глубоким, высокие — тонким и звонким"
                                            Header="Высота голоса"
                                            Icon="{LucideIconContent AudioLines,
                                                                     20}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Slider
                                                    Maximum="2.0"
                                                    Minimum="0.0"
                                                    Value="{Binding Pitch, Mode=TwoWay}" />
                                                <TextBox
                                                    Width="64"
                                                    HorizontalContentAlignment="Center"
                                                    Text="{Binding Pitch, Mode=TwoWay, StringFormat='{}{0:0.0}'}" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Ясность и звонкость произношения. Повышает четкость и разборчивость слов"
                                            Header="Верхние частоты"
                                            Icon="{LucideIconContent ChartNoAxesColumnIncreasing,
                                                                     20}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Slider
                                                    Maximum="10.0"
                                                    Minimum="-10.0"
                                                    Value="{Binding Treble, Mode=TwoWay}" />
                                                <TextBox
                                                    Width="64"
                                                    HorizontalContentAlignment="Center"
                                                    Text="{Binding Treble, Mode=TwoWay, StringFormat='{}{0:0.0}'}" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Глубина и плотность голоса. Помогает убрать писклявость"
                                            Header="Нижние частоты"
                                            Icon="{LucideIconContent ChartNoAxesColumnDecreasing,
                                                                     20}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Slider
                                                    Maximum="10.0"
                                                    Minimum="-10.0"
                                                    Value="{Binding Bass, Mode=TwoWay}" />
                                                <TextBox
                                                    Width="64"
                                                    HorizontalContentAlignment="Center"
                                                    Text="{Binding Bass, Mode=TwoWay, StringFormat='{}{0:0.0}'}" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Margin="24,12" IsVisible="{Binding #ModelAppearence.IsSelected}">
                                <TextBlock
                                    Margin="24,6,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Text="Модель" />
                                <Border Theme="{DynamicResource SettingsGroup}">
                                    <StackPanel>
                                        <views:SettingsCard
                                            Description="Выбор модели персонажа с устройства. Скачанные .vrm файлы моделей доступны по пути /какой-то/путь. В эту же директорию файл модели скопируется при добавлении"
                                            Header="Модель персонажа"
                                            Icon="{LucideIconContent Box,
                                                                     Size=20}">
                                            <Grid>
                                                <Button
                                                    Classes="word-button"
                                                    Command="{Binding OpenModel3DFileCommand}"
                                                    Content="Добавить" 
                                                    IsVisible="{Binding !IsModel3DLoading}"/>
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    IsVisible="{Binding IsModel3DLoading}"
                                                    Spacing="6">
                                                    <Arc
                                                        Width="16"
                                                        Height="16"
                                                        Classes="loading"
                                                        StartAngle="0"
                                                        Stroke="{DynamicResource SystemAccentColor}"
                                                        StrokeJoin="Round"
                                                        StrokeLineCap="Round"
                                                        StrokeThickness="1.5"
                                                        SweepAngle="270">
                                                        <Arc.Transitions>
                                                            <Transitions>
                                                                <DoubleTransition Property="RotateTransform.Angle" Duration="0:0:1" />
                                                            </Transitions>
                                                        </Arc.Transitions>
                                                        <Arc.RenderTransform>
                                                            <RotateTransform />
                                                        </Arc.RenderTransform>
                                                    </Arc>
                                                    <TextBlock Foreground="{DynamicResource SystemAccentColor}" Text="Загрузка модели" />
                                                </StackPanel>
                                            </Grid>
                                        </views:SettingsCard>
                                        <ListBox
                                            Margin="-3,8,-3,0"
                                            Background="Transparent"
                                            IsEnabled="{Binding !IsModel3DLoading}"
                                            ItemsSource="{Binding Models3D}"
                                            SelectedItem="{Binding SelectedModel3D, Mode=TwoWay}">
                                            <ListBox.Styles>
                                                <Style Selector="ListBoxItem">
                                                    <Setter Property="Height" Value="30" />
                                                    <Setter Property="Padding" Value="14,0" />
                                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                                    <Setter Property="Margin" Value="3" />
                                                    <Setter Property="CornerRadius" Value="15" />
                                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight3}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark3}" />
                                                </Style>
                                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark3}" />
                                                </Style>
                                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark3}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorLight3}" />
                                                </Style>
                                                <Style Selector="ListBoxItem:disabled /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="{DynamicResource SystemListLowColor}"/>
                                                </Style>
                                                <Style Selector="ListBoxItem:disabled:selected /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="{DynamicResource SystemListMediumColor}"/>
                                                </Style>
                                            </ListBox.Styles>
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                        <Separator />
                                        <views:SettingsCard
                                            Description="Путь к папке, в которую должны добавляться модели"
                                            Header="Папка моделей"
                                            Icon="{LucideIconContent FolderClosed,
                                                                     Size=20}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border
                                                    MaxWidth="260"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource SystemAccentColorLight3}"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        Margin="0"
                                                        Padding="6,2,6,2"
                                                        FontFamily="{Binding SelectedMonoFontFamily, Source={x:Static vm:SettingsVM.Instance}}"
                                                        Foreground="{DynamicResource SystemAccentColorDark3}"
                                                        Text="{Binding Model3DFolder}"
                                                        TextTrimming="LeadingCharacterEllipsis" />
                                                </Border>
                                                <Button
                                                    Classes="word-button"
                                                    Command="{Binding ChangeModel3DFolderCommand}"
                                                    Content="Изменить" />
                                            </StackPanel>
                                        </views:SettingsCard>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Grid.RowSpan="2"
                        Margin="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Classes="icon-button"
                        Command="{Binding SettingsCommand}">
                        <LucideIcon Kind="X" Size="18" />
                    </Button>
                </Grid>
            </Border>
            <!--  Prompt Editor  -->
            <Border
                MaxWidth="800"
                MaxHeight="500"
                Margin="52"
                Padding="16,12,16,12"
                Background="{DynamicResource SystemChromeLowColor}"
                BorderThickness="1"
                CornerRadius="8"
                IsVisible="{Binding IsPromptEditorOpen}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="DemiBold"
                        Text="Редактировать промпт" />
                    <TextBox
                        Grid.Row="1"
                        Height="NaN"
                        Margin="0,12"
                        Padding="12"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Top"
                        x:DataType="vm:SettingsVM"
                        AcceptsReturn="True"
                        AcceptsTab="True"
                        DataContext="{x:Static vm:SettingsVM.Instance}"
                        Text="{Binding SelectedArchetype.Prompt, Mode=TwoWay}"
                        TextWrapping="Wrap" />
                    <StackPanel
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Classes="word-button"
                            Command="{Binding SavePromptCommand}"
                            Content="Сохранить" />
                        <Button
                            Classes="word-button"
                            Command="{Binding PromptEditorCommand}"
                            Content="Отмена" />
                    </StackPanel>
                    <Button
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Classes="icon-button"
                        Command="{Binding PromptEditorCommand}">
                        <LucideIcon Kind="X" Size="18" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
        <!--  Startup  -->
        <StackPanel
            VerticalAlignment="Center"
            IsVisible="{Binding IsInitializing}"
            Spacing="16">
            <TextBlock HorizontalAlignment="Center" Text="{Binding InitializingMessage}" />
            <ProgressBar
                Height="8"
                MaxWidth="1000"
                Margin="100,0"
                CornerRadius="3"
                IsIndeterminate="{Binding IsInitializing}"
                IsVisible="{Binding IsInitializing}" />
        </StackPanel>
    </Grid>
</Window>
