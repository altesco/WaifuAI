<Styles
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:views="clr-namespace:WaifuAI.Views">
	<Style Selector="views|SidePanel">
		<Setter Property="Template">
			<ControlTemplate>
				<Grid RowDefinitions="Auto,*">
					<Border Height="48" BorderThickness="0,0,0,1">
						<TextBlock
							Margin="16,0,16,0"
							VerticalAlignment="Center"
							FontSize="18"
							FontWeight="Bold"
							Text="{TemplateBinding Header}"
							TextTrimming="CharacterEllipsis" />
					</Border>
					<ContentPresenter 
						Grid.Row="1"
						Content="{TemplateBinding InnerContent}"/>
				</Grid>
			</ControlTemplate>
		</Setter>
	</Style>
</Styles>
